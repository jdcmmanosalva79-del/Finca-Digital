# Variables de entorno para el servidor Finca Digital
# Copia este archivo como .env y rellena los valores reales.

PORT=4000

# ── OpenWeatherMap ──────────────────────────────────────
OPENWEATHER_API_KEY=TU_API_KEY_AQUI

# ── WhatsApp Provider: "ultramsg" o "twilio" ───────────
WHATSAPP_PROVIDER=ultramsg

# UltraMsg (si usas UltraMsg)
ULTRAMSG_INSTANCE_ID=TU_INSTANCE_ID
ULTRAMSG_TOKEN=TU_TOKEN

# Twilio (si usas Twilio)
TWILIO_ACCOUNT_SID=TU_ACCOUNT_SID
TWILIO_AUTH_TOKEN=TU_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
