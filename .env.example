# ─────────────────────────────────────────────────────────
# Variables de entorno para el proyecto Finca Digital
# Copia este archivo como .env y completa los valores reales.
# En Netlify: agrega estas variables en Site → Environment variables
# ─────────────────────────────────────────────────────────

# ── OpenWeatherMap ──────────────────────────────────────
OPENWEATHER_API_KEY=TU_API_KEY_AQUI

# ── WhatsApp Provider: "ultramsg" o "twilio" ───────────
WHATSAPP_PROVIDER=ultramsg

# UltraMsg
ULTRAMSG_INSTANCE_ID=TU_INSTANCE_ID
ULTRAMSG_TOKEN=TU_TOKEN

# Twilio (alternativa)
TWILIO_ACCOUNT_SID=TU_ACCOUNT_SID
TWILIO_AUTH_TOKEN=TU_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Firebase Admin SDK ─────────────────────────────────
# OPCIÓN A (recomendada para Netlify):
#   Pega el contenido completo del serviceAccountKey.json como una sola línea JSON
FIREBASE_SERVICE_ACCOUNT_JSON=

# OPCIÓN B (variables individuales):
# FIREBASE_PROJECT_ID=finca-digital-51f2f
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@finca-digital-51f2f.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
